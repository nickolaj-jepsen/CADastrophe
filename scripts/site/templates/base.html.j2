<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% block title %}{{ site_title }}{% endblock %}</title>
<link rel="stylesheet" href="{{ rel }}static/style.css">
{% block head %}{% endblock %}
</head>
<body>
<header class="topbar">
  <a class="brand" href="{{ rel }}index.html">{{ site_title }}</a>
  {% if repo %}<a class="gh" href="https://github.com/{{ repo }}">GitHub ↗</a>{% endif %}
</header>
<main>
{% block content %}{% endblock %}
</main>
<footer>
  Generated by <code>scad site</code>
  {% if repo %} · <a href="https://github.com/{{ repo }}">{{ repo }}</a>
  · <a href="https://github.com/{{ repo }}/releases/tag/latest">all downloads</a>{% endif %}
</footer>
</body>
</html>
